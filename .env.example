PORT=3000
NODE_ENV=development

# Storage backend
# - memory: local JSON file storage
# - mongo: MongoDB / Atlas
STORAGE_MODE=mongo

# Allowed browser origins for API requests.
# Local example:
# CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Vercel example:
# CORS_ORIGINS=https://your-project.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# MongoDB connection string (local or hosted)
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017/blustup
# Atlas example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/blustup?retryWrites=true&w=majority&appName=blustup
MONGODB_URI=mongodb://127.0.0.1:27017/blustup

JWT_SECRET=dev-only-change-me

# First-run admin bootstrap (recommended):
# - set ADMIN_EMAIL to your admin email
# - set ADMIN_PASSWORD to the initial password
ADMIN_EMAIL=admin@blustup.local
ADMIN_PASSWORD=change-me

# Optional alternative bootstrap:
# ADMIN_PASSWORD_HASH=... (bcrypt hash)
# If both are provided, ADMIN_PASSWORD_HASH wins.
ADMIN_PASSWORD_HASH=

# Optional salt rounds for hashing ADMIN_PASSWORD (bcrypt)
BCRYPT_SALT_ROUNDS=12

# Paystack payment gateway (get keys from dashboard.paystack.com)
# Test keys start with sk_test_ / pk_test_
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Optional OpenAI integration for AI chatbot + AI search.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional SMTP config for automated report emails.
# Cron-based reports will still generate without these,
# but email delivery needs all of the values below.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REPORT_EMAIL_FROM=

