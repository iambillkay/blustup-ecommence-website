{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "version": 2,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": ["server/storage/memory-state.json", "public/index.html"],
      "maxDuration": 15
    }
  }
}
